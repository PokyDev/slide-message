    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  },
  "keywords": [
    "react",
    "notification",
    "toast",
    "slide",
    "animation",
    "ui",
    "component"
  ],
