{
  "name": "slide-message",
  "version": "1.0.0",
  "description": "A lightweight React notification system with slide animations, variant support, and themeable CSS custom properties.",
  "type": "module",
  "main": "./dist/slide-message.cjs",
  "module": "./dist/slide-message.js",
  "exports": {
    ".": {
      "import": "./dist/slide-message.js",
      "require": "./dist/slide-message.cjs"
    },
